<%- include('./partials/head.ejs') %>
<body>
    <%- include('./partials/nav.ejs') %>
    <div class="container">
        <h2>Welcome to ToDo App!</h2>
        <% if(todos.length > 0){ %>
            <% todos.forEach(todo=> { %>
                <h4><%= todo.task %></h4>
            <% }) %>
        <% }else{ %>
            <p>There are no todos for now</p>
        <% } %>
    </div>
    <%- include('./partials/footer.ejs') %>
</body>
</html>